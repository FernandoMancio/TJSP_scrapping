from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.chrome.service import Service
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from webdriver_manager.chrome import ChromeDriverManager
import pandas as pd
import time

# Lista de números de processos
numeros_processos = [
'xxxxxxx-xx.2025.8.26.xxxx',
'yyyyyyy-yy.2024.8.26.yyyy'
]

# Caminho do ChromeDriver atualizado para o local correto
service = Service(ChromeDriverManager().install())
driver = webdriver.Chrome(service=service)

# URL do site de consulta do TJSP (2ª instância)
url_base = "https://esaj.tjsp.jus.br/cposg/open.do"

# Listas para armazenar os dados coletados
dados_processos_com_sucesso = []
dados_processos_com_erro = []
dados_processos_outro_erro = []

# Caminho para salvar a planilha
caminho_planilha = r"C:\Users\seu_path\05_2_instancia.xlsx"

def salvar_planilha():
    with pd.ExcelWriter(caminho_planilha) as writer:
        df_sucesso = pd.DataFrame(dados_processos_com_sucesso)
        df_erro = pd.DataFrame(dados_processos_com_erro)
        df_outro_erro = pd.DataFrame(dados_processos_outro_erro)

        # Salva os dados nas abas respectivas
        df_sucesso.to_excel(writer, sheet_name="Processos com Sucesso", index=False)
        df_erro.to_excel(writer, sheet_name="Processos com Erro", index=False)
        df_outro_erro.to_excel(writer, sheet_name="Outro Erro", index=False)
    print("Planilha salva com sucesso!")

for numero in numeros_processos:
    print(f"\nIniciando extração do processo: {numero}")
    driver.get(url_base)  # Acessa a página inicial
    time.sleep(2)  # Aguarda a página carregar

    try:
        # Preenche o campo do número do processo
        campo_processo = WebDriverWait(driver, 10).until(
            EC.presence_of_element_located((By.ID, "numeroDigitoAnoUnificado"))
        )
        campo_processo.clear()
        campo_processo.send_keys(numero[:15])
        print(f"Número inserido no campo principal: {numero[:15]}")

        # Preenche o campo "foroNumeroUnificado" com os últimos 4 caracteres
        campo_foro = driver.find_element(By.ID, "foroNumeroUnificado")
        campo_foro.clear()
        campo_foro.send_keys(numero[-4:])
        print(f"Foro inserido: {numero[-4:]}")

        # Clica no botão "Consultar" com espera de 5 segundos
        botao_consultar = WebDriverWait(driver, 5).until(
            EC.element_to_be_clickable((By.ID, "pbConsultar"))
        )
        botao_consultar.click()

        # Aguarda a página de resultados carregar
        time.sleep(3)

        # Verifica a existência da mensagem de erro
        mensagem_erro = driver.find_elements(By.ID, "mensagemRetorno")
        if mensagem_erro:
            dados_processos_com_erro.append({
                "Número do Processo": numero,
                "Situação": "Não Localizado"
            })
            salvar_planilha()  # Salva a planilha após processar o erro
            continue  # Passa imediatamente para a próxima iteração

        # Clica no primeiro botão "Mais" (Detalhes)
        try:
            botao_mais_detalhes = WebDriverWait(driver, 5).until(
                EC.element_to_be_clickable((By.CSS_SELECTOR, "a[href='#maisDetalhes']"))
            )
            botao_mais_detalhes.click()
            time.sleep(1)  # Aguarda o conteúdo expandir
        except Exception as e:
            print(f"Erro ao clicar no primeiro botão 'Mais': {e}")

        # Extrai os dados do processo
        try:
            numero_processo = driver.find_element(By.ID, "numeroProcesso").text
        except Exception as e:
            print(f"Erro ao extrair número do processo: {e}")
            numero_processo = "Não Localizado"

        try:
            situacao = driver.find_element(By.ID, "situacaoProcesso").text
        except Exception as e:
            print(f"Erro ao extrair situação: {e}")
            situacao = "Não Localizado"

        try:
            secao = driver.find_element(By.ID, "secaoProcesso").text
        except Exception as e:
            print(f"Erro ao extrair seção: {e}")
            secao = "Não Localizado"

        try:
            camara = driver.find_element(By.ID, "orgaoJulgadorProcesso").text
        except Exception as e:
            print(f"Erro ao extrair câmara: {e}")
            camara = "Não Localizado"

        try:
            relator = driver.find_element(By.ID, "relatorProcesso").text
        except Exception as e:
            print(f"Erro ao extrair relator: {e}")
            relator = "Não Localizado"

        # Coleta as informações de julgamento
        data_julgamento = "Não Localizado"
        situacao_julgamento = "Não Localizado"
        decisao = "Não Localizado"

        try:
            # Localiza a tabela com o estilo específico
            tabela_julgamento = driver.find_elements(By.CSS_SELECTOR, "table[style*='margin-left:15px; margin-top:1px;']")
            if tabela_julgamento:
                for tabela in tabela_julgamento:
                    linhas = tabela.find_elements(By.CSS_SELECTOR, "tr.fundoClaro")
                    for linha in linhas:
                        colunas = linha.find_elements(By.TAG_NAME, "td")
                        if len(colunas) >= 3 and colunas[1].text.strip().lower() == "julgado":
                            data_julgamento = colunas[0].text.strip()
                            situacao_julgamento = colunas[1].text.strip()
                            decisao = f"{situacao_julgamento}: {colunas[2].text.strip()}"
                            print(f"Decisão encontrada: {data_julgamento} - {decisao}")
                            break
                    if data_julgamento != "Não Localizado":
                        break
            else:
                print("Tabela de julgamento não encontrada")
        except Exception as e:
            print(f"Erro ao coletar informações de julgamento: {e}")

        # Subprocessos e recursos
        try:
            subprocessos = driver.find_element(By.ID, "processoSemIncidentes").text
        except Exception as e:
            print(f"Erro ao extrair subprocessos: {e}")
            subprocessos = "Não Localizado"

        # Resultado do acórdão
        resultado_acordao = decisao if decisao != "Não Localizado" else "Não Localizado"

        # Adiciona os dados na lista de sucesso
        dados_processos_com_sucesso.append({
            "Número do Processo Procurado": numero,  # Nova coluna com o número original
            "Número do Processo": numero_processo,
            "Situação": situacao,
            "Seção": secao,
            "Câmara": camara,
            "Relator": relator,
            "Data do Julgamento": data_julgamento,
            "Situação do Julgamento": situacao_julgamento,
            "Decisão": decisao,
            "Subprocessos e Recursos": subprocessos,
            "Resultado do Acórdão": resultado_acordao
        })
        salvar_planilha()  # Salva a planilha após processar com sucesso
    except Exception as e:
        print(f"Erro ao processar o processo {numero}: {e}")
        dados_processos_outro_erro.append({
            "Número do Processo": numero,
            "Retorno": "Não Localizado"
        })
        salvar_planilha()  # Salva a planilha após registrar o erro

# Fecha o navegador
driver.quit()
