from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.chrome.service import Service
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from selenium.common.exceptions import NoSuchElementException, TimeoutException
from webdriver_manager.chrome import ChromeDriverManager
import pandas as pd
import re, logging

# Configura logging para depuração
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')

# Lista de números de processos
numeros_processos = [
'xxxxxxx-xx.2011.8.26.xxxx',
'yyyyyyy-yy.2008.8.26.yyyy'
]

# URL do site de consulta do TJSP (1ª instância)
url_base = "https://esaj.tjsp.jus.br/cpopg/open.do"

# Caminho para salvar a planilha
caminho_planilha = r"C:\Users\seu_path\01_Juiz_Processo.xlsx"

# Validação de números de processos
def validar_numero_processo(numero):
    pattern = r'^\d{7}-\d{2}\.\d{4}\.\d\.\d{2}\.\d{4}$'
    return bool(re.match(pattern, numero))

# Função para processar um único processo
def processar_processo(numero):
    if not validar_numero_processo(numero):
        logging.error(f"Número de processo inválido: {numero}")
        return None

    # Configura o driver (modo headless)
    options = webdriver.ChromeOptions()
    options.add_argument("--headless")
    options.add_argument("--disable-gpu")
    options.add_argument("--no-sandbox")
    service = Service(ChromeDriverManager().install())
    driver = webdriver.Chrome(service=service, options=options)

    try:
        logging.info(f"Iniciando extração do processo: {numero}")

        # Carrega a página
        driver.get(url_base)
        WebDriverWait(driver, 10).until(
            EC.presence_of_element_located((By.ID, "numeroDigitoAnoUnificado"))
        )

        # Preenche os campos
        campo_processo = driver.find_element(By.ID, "numeroDigitoAnoUnificado")
        campo_processo.clear()
        campo_processo.send_keys(numero[:15])

        campo_foro = driver.find_element(By.ID, "foroNumeroUnificado")
        campo_foro.clear()
        campo_foro.send_keys(numero[-4:])

        # Clica no botão "Consultar"
        botao_consultar = WebDriverWait(driver, 10).until(
            EC.element_to_be_clickable((By.ID, "botaoConsultarProcessos"))
        )
        botao_consultar.click()

        # ── Extrai o nome do juiz ──────────────────────────────────────────
        try:
            juiz = WebDriverWait(driver, 10).until(
                EC.presence_of_element_located((By.ID, "juizProcesso"))
            ).text.strip()
        except (NoSuchElementException, TimeoutException):
            juiz = ""
            logging.warning(f"Juiz não encontrado para o processo {numero}")

        # ── Extrai o assunto ───────────────────────────────────────────────
        # Tenta primeiro pelo texto visível do <span id="assuntoProcesso">
        # e, como fallback, usa o atributo title (que pode ser mais completo)
        try:
            elemento_assunto = WebDriverWait(driver, 10).until(
                EC.presence_of_element_located((By.ID, "assuntoProcesso"))
            )
            # O atributo title costuma conter o texto completo quando truncado
            assunto = (elemento_assunto.get_attribute("title") or
                       elemento_assunto.text).strip()
        except (NoSuchElementException, TimeoutException):
            assunto = ""
            logging.warning(f"Assunto não encontrado para o processo {numero}")

        dados_processo = {
            "Numero_Processo": numero,
            "Juiz": juiz,
            "Assunto": assunto
        }

        logging.info(
            f"Processo {numero} extraído com sucesso — "
            f"Juiz: {juiz} | Assunto: {assunto}"
        )
        return dados_processo

    except Exception as e:
        logging.error(f"Erro ao processar o processo {numero}: {e}")
        return {"Numero_Processo": numero, "Juiz": "ERRO", "Assunto": "ERRO"}

    finally:
        driver.quit()


# ── Processamento sequencial ───────────────────────────────────────────────────
dados_processos = []
for numero in numeros_processos:
    result = processar_processo(numero)
    if result:
        dados_processos.append(result)

# ── Salva os dados na planilha ─────────────────────────────────────────────────
if dados_processos:
    df = pd.DataFrame(dados_processos, columns=["Numero_Processo", "Juiz", "Assunto"])
    df.to_excel(caminho_planilha, index=False)
    logging.info(f"Planilha salva com {len(dados_processos)} processos em: {caminho_planilha}")
else:
    logging.info("Nenhum dado foi coletado para salvar na planilha")

logging.info("Processo de extração concluído!")
